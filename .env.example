# ============================================
# Wareed AI Medical Assistant - Environment Variables
# ============================================

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model Settings
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# RAG: minimum cosine similarity (0.0-1.0) to allow answer. Below = "no info" response.
# 0.58 improves recall for symptom-based queries (نوم، مزاج، معدة، فيتامين د)
RAG_SIMILARITY_THRESHOLD=0.58

# Application Settings
APP_NAME=Wareed AI Medical Assistant
APP_VERSION=0.1.0
DEBUG=False

# Database Configuration (PostgreSQL - REQUIRED for Production)
# Server: chat.wareed.com.sa | DB: chat_user | User: chat_user (Plesk PostgreSQL v18.1)
# Format: postgresql://user:password@host:port/database
# - On same server as DB use host=localhost; for remote use host=chat.wareed.com.sa (enable remote in Plesk)
# - If password contains # or ~ replace in URL: # → %23, ~ → %7E
DATABASE_URL=postgresql://chat_user:YOUR_DB_PASSWORD@localhost:5432/chat_user

# Local Development Override (use .env.local)
# Create a separate .env.local to keep local DB settings isolated from production.
# Example:
# DATABASE_URL=postgresql://postgres:YOUR_LOCAL_PASSWORD@localhost:5432/wareed_db

# Database Connection Pool Settings (Optional - defaults provided)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Redis (required for shared conversation state across stateless workers)
# Render typically provides REDIS_URL via managed Redis service.
REDIS_URL=redis://localhost:6379/0
CONVERSATION_STATE_TTL_SECONDS=3600

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/wareed_app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Security - CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT Authentication (platform-agnostic: Web + Mobile, Bearer only, no cookies/sessions)
# Generate a strong secret in production: e.g. openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20

# ============================================
# IMPORTANT NOTES:
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env to version control
# 3. Keep your API keys secure
# ============================================
